# Example .env for backend
DATABASE_URL=postgres://defecttracker:defecttracker@localhost:5432/defecttracker
PORT=3000
JWT_SECRET=change_this_to_a_secure_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpass
FRONTEND_URL=http://localhost:5173   # set to your Vercel URL in production
# Supabase settings
# NOTE: Do NOT put real secret keys in this example file. Create a local
# `.env` from this file and paste your real values there. Never commit `.env`.
# For server-side uploads use the service_role key (keep it secret, backend only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key    # backend: use service_role key (do NOT commit)
SUPABASE_BUCKET=uploads
